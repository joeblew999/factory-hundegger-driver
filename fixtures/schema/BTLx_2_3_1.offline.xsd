							<xs:choice minOccurs="1" maxOccurs="unbounded">
								<xs:group ref="ProcessingElements"/>
							</xs:choice>
						</xs:complexType>
					</xs:element>
					<xs:element name="ConnectorInfo" type="ConnectorInfoType"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="VariantType">
		<xs:annotation>
			<xs:documentation>Definition of a variant</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="ProcessingType">
				<xs:sequence>
					<xs:element name="Orientation" type="OrientationType" minOccurs="0"/>
					<xs:element name="CutOff" type="BooleanType" default="no" minOccurs="0"/>
					<xs:element name="StartX" type="LengthPosType" minOccurs="0"/>
					<xs:element name="StartY" type="LengthPosType" minOccurs="0"/>
					<xs:element name="StartDepth" type="LengthPosType" minOccurs="0"/>
					<xs:sequence minOccurs="0" maxOccurs="unbounded">
						<xs:element name="VariantParameter" type="ParameterType"/>
					</xs:sequence>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!---->
	<!--NURBS definitions-->
	<xs:complexType name="NURBSCurveBaseType">
		<xs:annotation>
			<xs:documentation>Definition of a NURBS curve</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ControlPoints">
				<xs:annotation>
					<xs:documentation>list of control points ordered from 0 to Count-1</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="2" maxOccurs="unbounded">
						<xs:element name="ControlPoint" type="ControlPointType"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Knots" type="KnotListType">
				<xs:annotation>
					<xs:documentation>number of knots = Count + Degree</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="Degree" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>degree</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="Count" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>number of control points</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="NURBSCurveType">
		<xs:annotation>
			<xs:documentation>Definition of a NURBS curve</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="NURBSCurveBaseType">
				<xs:attribute name="Process" type="BooleanType"/>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="NURBSPatchType">
		<xs:annotation>
			<xs:documentation>Definition of a NURBS patch</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ControlPoints">
				<xs:annotation>
					<xs:documentation>the list of control points is organized row wise with CountV rows and CountU control points per row, i.e.: CP(U=0, V=0), CP(U=1, V=0), ..., CP(U=CountU-1, V=0), CP(U=0, V=1), ..., CP(U=CountU-1, V=1), ...</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="2" maxOccurs="unbounded">
						<xs:element name="ControlPoint" type="ControlPointType"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="KnotsU" type="KnotListType">
				<xs:annotation>
					<xs:documentation>number of knots in U = Count in U + Degree in U</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="KnotsV" type="KnotListType">
				<xs:annotation>
					<xs:documentation>number of knots in V = Count in V + Degree in V</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="DegreeU" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>degree in U</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="DegreeV" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>degree in V</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="CountU" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>number of control points in U</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="CountV" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>number of control points in V</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<!--alternative NURBS patch definition-->
	<xs:complexType name="NURBSCurveBType">
		<xs:annotation>
			<xs:documentation>Definition of a NURBS curve</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ControlPoints">
				<xs:annotation>
					<xs:documentation>list of control points ordered from U=0 to U=Count-1</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="2" maxOccurs="unbounded">
						<xs:element name="ControlPoint" type="ControlPointType"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="KnotsU" type="KnotListType">
				<xs:annotation>
					<xs:documentation>number of knots = Count + Degree</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="DegreeU" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>degree of the curve</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="CountU" type="xs:positiveInteger" use="required">
			<xs:annotation>
				<xs:documentation>number of control points</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="NURBSPatchDerivType">
		<xs:annotation>
			<xs:documentation>Definition of a NURBS patch</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="NURBSCurveBType">
				<xs:sequence>
					<xs:element name="KnotsV" type="KnotListType">
						<xs:annotation>
							<xs:documentation>number of knots in V = Count in V + Degree in V</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
				<xs:attribute name="DegreeV" type="xs:positiveInteger" use="required">
					<xs:annotation>
						<xs:documentation>degree in V</xs:documentation>
					</xs:annotation>
				</xs:attribute>
				<xs:attribute name="CountV" type="xs:positiveInteger" use="required">
					<xs:annotation>
						<xs:documentation>number of control points in V</xs:documentation>
					</xs:annotation>
				</xs:attribute>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!-- ================================================================== -->
	<!--basic contour definitions-->
	<!-- ================================================================== -->
	<xs:complexType name="PointType">
		<xs:annotation>
			<xs:documentation>Definition of a contour point</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="CoordinateType"/>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="LineBaseType">
		<xs:annotation>
			<xs:documentation>Definition of a contour line</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EndPoint" type="CoordinateType"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="LineType">
		<xs:annotation>
			<xs:documentation>Definition of a contour line</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="LineBaseType">
				<xs:attribute name="Process" type="BooleanType"/>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="ArcBaseType">
		<xs:annotation>
			<xs:documentation>Definition of a contour arc</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="LineBaseType">
				<xs:sequence>
					<xs:element name="PointOnArc" type="CoordinateType"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="ArcType">
		<xs:annotation>
			<xs:documentation>Definition of a contour arc</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="LineBaseType">
				<xs:sequence>
					<xs:element name="PointOnArc" type="CoordinateType"/>
				</xs:sequence>
				<xs:attribute name="Process" type="BooleanType"/>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!---->
	<xs:complexType name="SimpleContourBaseType">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice minOccurs="0" maxOccurs="unbounded">
				<xs:element name="Line" type="LineBaseType"/>
				<xs:element name="Arc" type="ArcBaseType"/>
				<xs:element name="NURBS" type="NURBSCurveBaseType">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SimpleContourBase1Type">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice maxOccurs="unbounded">
				<xs:element name="Line" type="LineBaseType"/>
				<xs:element name="Arc" type="ArcBaseType"/>
				<xs:element name="NURBS" type="NURBSCurveBaseType">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SimpleContourBase2Type">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice minOccurs="2" maxOccurs="unbounded">
				<xs:element name="Line" type="LineBaseType"/>
				<xs:element name="Arc" type="ArcBaseType"/>
				<xs:element name="NURBS" type="NURBSCurveBaseType">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SimpleContourType">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice minOccurs="0" maxOccurs="unbounded">
				<xs:element name="Line" type="LineType"/>
				<xs:element name="Arc" type="ArcType"/>
				<xs:element name="NURBS" type="NURBSCurveType">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SimpleContour1Type">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice maxOccurs="unbounded">
				<xs:element name="Line" type="LineType"/>
				<xs:element name="Arc" type="ArcType"/>
				<xs:element name="NURBS" type="NURBSCurveType">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SimpleContourIncType">
		<xs:annotation>
			<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartPoint" type="PointType"/>
			<xs:choice minOccurs="0" maxOccurs="unbounded">
				<xs:element name="Line">
					<xs:complexType>
						<xs:complexContent>
							<xs:extension base="LineType">
								<xs:attributeGroup ref="SingleContourAttributes"/>
							</xs:extension>
						</xs:complexContent>
					</xs:complexType>
				</xs:element>
				<xs:element name="Arc">
					<xs:complexType>
						<xs:complexContent>
							<xs:extension base="ArcType">
								<xs:attributeGroup ref="SingleContourAttributes"/>
							</xs:extension>
						</xs:complexContent>
					</xs:complexType>
				</xs:element>
				<xs:element name="NURBS">
					<xs:annotation>
						<xs:documentation>the first control point U=0 has to be identical to the endpoint of the previous segment</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:complexContent>
							<xs:extension base="NURBSCurveType">
								<xs:attributeGroup ref="SingleContourAttributes"/>
							</xs:extension>
						</xs:complexContent>
					</xs:complexType>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DualContourType">
		<xs:annotation>
			<xs:documentation>Definiton of a dual contour (one contour and one associated contour)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PrincipalContour" type="SimpleContourType"/>
			<xs:element name="AssociatedContour" type="SimpleContourBaseType"/>
		</xs:sequence>
	</xs:complexType>
	<!-- ================================================================== -->
	<!--contour processing definitions-->
	<!-- ================================================================== -->
	<xs:complexType name="OutlineBaseType">
		<xs:annotation>
			<xs:documentation>Definition of an base type for outlines</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:choice>
				<xs:element name="Contour" type="SimpleContourIncType"/>
				<xs:element name="DualContour">
					<xs:complexType>
						<xs:complexContent>
							<xs:extension base="DualContourType"/>
						</xs:complexContent>
					</xs:complexType>
				</xs:element>
			</xs:choice>
			<xs:element name="Silhouette" type="SimpleContourBaseType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OutlineType">
		<xs:annotation>
			<xs:documentation>Definition of an outline</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="OutlineBaseType">
				<xs:sequence>
					<xs:element name="Apertures" minOccurs="0">
						<xs:complexType>
							<xs:sequence maxOccurs="unbounded">
								<xs:element name="Aperture">
									<xs:complexType>
										<xs:complexContent>
											<xs:extension base="OutlineBaseType">
												<xs:attribute name="Process" type="BooleanType" default="no"/>
											</xs:extension>
										</xs:complexContent>
									</xs:complexType>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
				</xs:sequence>
				<xs:attribute name="ReferencePlaneID" use="required">
					<xs:simpleType>
						<xs:restriction base="xs:unsignedInt">
							<xs:minInclusive value="1"/>
							<xs:maxInclusive value="6"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
				<xs:attribute name="Process" type="BooleanType" default="no"/>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="FreeContourType">
		<xs:annotation>
			<xs:documentation>Definition of a base contour (either a contour or a contour with associated contour)</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="ProcessingType">
				<xs:sequence>
					<xs:choice>
						<xs:element name="Contour">
							<xs:complexType>
								<xs:annotation>
									<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
								</xs:annotation>
								<xs:sequence>
									<xs:element name="StartPoint" type="PointType"/>
									<xs:choice minOccurs="0" maxOccurs="unbounded">
										<xs:element name="Line">
											<xs:complexType>
												<xs:complexContent>
													<xs:extension base="LineType">
														<xs:attributeGroup ref="SingleContourAttributes"/>
														<xs:attributeGroup ref="FreeContourAttributes"/>
													</xs:extension>
												</xs:complexContent>
											</xs:complexType>
										</xs:element>
										<xs:element name="Arc">
											<xs:complexType>
												<xs:complexContent>
													<xs:extension base="ArcType">
														<xs:attributeGroup ref="SingleContourAttributes"/>
														<xs:attributeGroup ref="FreeContourAttributes"/>
													</xs:extension>
												</xs:complexContent>
											</xs:complexType>
										</xs:element>
										<xs:element name="NURBS">
											<xs:complexType>
												<xs:complexContent>
													<xs:extension base="NURBSCurveType">
														<xs:attributeGroup ref="SingleContourAttributes"/>
														<xs:attributeGroup ref="FreeContourAttributes"/>
													</xs:extension>
												</xs:complexContent>
											</xs:complexType>
										</xs:element>
									</xs:choice>
									<xs:element name="MachiningLimits" type="ContourMachiningLimitType" minOccurs="0"/>
								</xs:sequence>
								<xs:attribute name="DepthBounded" type="BooleanType" default="no"/>
								<xs:attribute name="Depth" type="LengthType" default="0.0"/>
								<xs:attribute name="Inclination" type="InclinationType" default="0.0"/>
							</xs:complexType>
						</xs:element>
						<xs:element name="DualContour">
							<xs:complexType>
								<xs:annotation>
									<xs:documentation>Definiton of a dual contour (one contour and one associated contour)</xs:documentation>
								</xs:annotation>
								<xs:sequence>
									<xs:element name="PrincipalContour">
										<xs:complexType>
											<xs:annotation>
												<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
											</xs:annotation>
											<xs:sequence>
												<xs:element name="StartPoint">
													<xs:complexType>
														<xs:complexContent>
															<xs:extension base="PointType"/>
														</xs:complexContent>
													</xs:complexType>
												</xs:element>
												<xs:choice minOccurs="0" maxOccurs="unbounded">
													<xs:element name="Line">
														<xs:complexType>
															<xs:complexContent>
																<xs:extension base="LineType">
																	<xs:attributeGroup ref="FreeContourAttributes"/>
																</xs:extension>
															</xs:complexContent>
														</xs:complexType>
													</xs:element>
													<xs:element name="Arc">
														<xs:complexType>
															<xs:complexContent>
																<xs:extension base="ArcType">
																	<xs:attributeGroup ref="FreeContourAttributes"/>
																</xs:extension>
															</xs:complexContent>
														</xs:complexType>
													</xs:element>
													<xs:element name="NURBS">
														<xs:complexType>
															<xs:complexContent>
																<xs:extension base="NURBSCurveType">
																	<xs:attributeGroup ref="FreeContourAttributes"/>
																</xs:extension>
															</xs:complexContent>
														</xs:complexType>
													</xs:element>
												</xs:choice>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="AssociatedContour" type="SimpleContourBaseType"/>
									<xs:element name="MachiningLimits" type="ContourMachiningLimitType" minOccurs="0"/>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:choice>
					<xs:element name="Apertures" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Apertures are only allowed if the Contour is closed</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence maxOccurs="unbounded">
								<xs:element name="Aperture">
									<xs:annotation>
										<xs:documentation>An Aperture must be closed. It has to be entirely inside the Countour without crossing or touching it.</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:choice>
											<xs:element name="Contour">
												<xs:complexType>
													<xs:annotation>
														<xs:documentation>Definition of a simple contour (one point and multiple lines and arcs)</xs:documentation>
													</xs:annotation>
													<xs:sequence>
														<xs:element name="StartPoint">
															<xs:complexType>
																<xs:complexContent>
																	<xs:extension base="PointType"/>
																</xs:complexContent>
															</xs:complexType>
														</xs:element>
														<xs:choice minOccurs="0" maxOccurs="unbounded">
															<xs:element name="Line">
																<xs:complexType>
																	<xs:complexContent>
																		<xs:extension base="LineType">
																			<xs:attributeGroup ref="SingleContourAttributes"/>
																			<xs:attributeGroup ref="FreeContourAttributes"/>
																		</xs:extension>
																	</xs:complexContent>
																</xs:complexType>
															</xs:element>
															<xs:element name="Arc">
																<xs:complexType>
																	<xs:complexContent>
																		<xs:extension base="ArcType">
																			<xs:attributeGroup ref="SingleContourAttributes"/>
																			<xs:attributeGroup ref="FreeContourAttributes"/>
																		</xs:extension>
																	</xs:complexContent>
																</xs:complexType>
															</xs:element>
															<xs:element name="NURBS">
																<xs:complexType>
																	<xs:complexContent>
																		<xs:extension base="NURBSCurveType">
																			<xs:attributeGroup ref="SingleContourAttributes"/>
																			<xs:attributeGroup ref="FreeContourAttributes"/>
																		</xs:extension>
																	</xs:complexContent>
																</xs:complexType>
															</xs:element>
														</xs:choice>
													</xs:sequence>
												</xs:complexType>
											</xs:element>
											<xs:element name="DualContour">
												<xs:complexType>
													<xs:annotation>
														<xs:documentation>Definiton of a dual contour (one contour and one associated contour)</xs:documentation>
													</xs:annotation>
													<xs:sequence>
														<xs:element name="PrincipalContour">
															<xs:complexType>
